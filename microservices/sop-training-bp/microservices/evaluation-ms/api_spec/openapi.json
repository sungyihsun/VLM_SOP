          },
          "ddm_training_job_id": {
            "type": "string",
            "title": "Ddm Training Job Id"
          },
          "val_dataset_id": {
            "type": "string",
            "title": "Val Dataset Id"
          },
          "status": {
            "type": "string",
            "title": "Status"
          },
          "overall_accuracy": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
