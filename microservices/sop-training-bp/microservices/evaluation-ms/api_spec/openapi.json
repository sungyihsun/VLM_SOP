        "properties": {
          "eval_job_id": {
            "type": "string",
            "title": "Eval Job Id"
          },
          "status": {
            "type": "string",
            "title": "Status"
          },
          "message": {
            "type": "string",
            "title": "Message"
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "title": "Created At"
          }
        },
        "type": "object",
        "required": [
          "eval_job_id",
          "status",
          "message",
          "created_at"
        ],
        "title": "E2eEvaluationResponse"
      },
