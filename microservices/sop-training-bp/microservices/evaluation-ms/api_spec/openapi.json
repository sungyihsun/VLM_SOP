  "components": {
    "schemas": {
      "E2eEvaluationRequest": {
        "properties": {
          "training_job_id": {
            "type": "string",
            "title": "Training Job Id"
          },
          "ddm_training_job_id": {
            "type": "string",
            "title": "Ddm Training Job Id"
          },
          "val_dataset_id": {
            "type": "string",
            "title": "Val Dataset Id"
          },
          "fps": {
            "type": "integer",
            "title": "Fps",
            "default": 8
          },
          "temperature": {
            "type": "number",
            "title": "Temperature",
            "default": 0.0
          },
          "backend": {
            "type": "string",
            "title": "Backend",
            "default": "vllm"
          },
          "checkpoint_step": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Checkpoint Step"
          },
          "ddm_checkpoint": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Ddm Checkpoint"
          },
          "resolution_config": {
            "anyOf": [
              {
                "additionalProperties": true,
                "type": "object"
              },
              {
                "type": "null"
              }
            ],
            "title": "Resolution Config"
          },
          "score_threshold": {
            "type": "number",
            "title": "Score Threshold",
            "default": 0.5
          },
          "nms_sec": {
            "type": "number",
            "title": "Nms Sec",
            "default": 0.0
          },
          "ddm_batch_size": {
            "type": "integer",
            "title": "Ddm Batch Size",
            "default": 8
          },
          "frames_per_segment_hint": {
            "type": "integer",
            "title": "Frames Per Segment Hint",
            "default": 256
          }
        },
        "type": "object",
        "required": [
          "training_job_id",
          "ddm_training_job_id",
          "val_dataset_id"
        ],
        "title": "E2eEvaluationRequest"
      },
