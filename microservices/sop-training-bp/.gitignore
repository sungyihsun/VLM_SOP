# Local-only superpowers session notes (plans, specs, reports). Kept in
# the working tree for the author's own reference but intentionally
# excluded from the repo — they're not part of the shipping artefact.
docs/superpowers/

# Runtime artefacts under assets/ — large training outputs, eval results,
# checkpoints, downloaded datasets. The bind-mounted host paths the
# microservices write to. Keep assets/config/ (committed configs) out
# of the ignore list. Without these rules, `git add -A` will try to
# ingest multi-GB checkpoint .pth files from completed training jobs.
assets/data/
assets/data_external/
assets/results/
assets/weights/
assets/logs/
assets/server_assemble/
assets/metadata_db/

# Recompose worktree (transient — cleaned up at end of recompose flow).
.recompose-worktrees/

