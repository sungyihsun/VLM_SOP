            "description": "Maximum number of tokens to generate. This is a placeholder for now."
          },
          "seed": {
            "anyOf": [
              {
                "type": "integer",
                "maximum": 1.8446744073709552E+19,
                "minimum": 0.0
              },
              {
                "type": "null"
              }
            ],
            "title": "Seed",
            "description": "Seed for the random number generator."
