        "properties": {
          "algorithm": {
            "type": "string",
            "const": "ddm-net",
            "title": "Algorithm",
            "description": "Algorithm for DdmNet chunking.",
            "default": "ddm-net"
          },
          "threshold": {
            "type": "number",
            "exclusiveMaximum": 1.0,
            "exclusiveMinimum": 0.1,
            "title": "Threshold",
            "description": "Threshold for DdmNet chunking. The lower, the more sensitive the chunking is.The value should be in (0.1, 1.0)Default is 0.8.",
            "default": 0.8
          },
          "min_length_sec": {
            "type": "number",
            "exclusiveMinimum": 0.0,
            "title": "Min Length Sec",
            "description": "Minimum length of a chunk in seconds. Default is 1.0 seconds.",
            "default": 1.0
          },
          "max_length_sec": {
            "type": "number",
            "exclusiveMinimum": 0.0,
            "title": "Max Length Sec",
            "description": "Hint for maximum length of a chunk in seconds. It is not garanteed that the chunk will be smaller than this value. But the algorithm will try to keep the chunk length below this value and not cut at the event boundaries. Default is 60 seconds.",
            "default": 60.0
          }
